# --- Raw media: keep the repo lean ---
# Full-res camera originals and video belong on a Release or YouTube, not in
# git history (blobs are permanent). Optimized, EXIF-stripped stills live in
# docs/images/ and are committed normally.
*.mp4
*.mov
*.MP4
*.MOV
PXL_*.jpg

# --- Secrets: never commit real credentials ---
secrets.h
Secrets.h
arduino_secrets.h
*.local.h
.env

# --- Arduino / ESP32 build output ---
build/
*.bin
*.elf
*.map
*.hex
*.d
*.o
*.a
.build/
*.ino.cpp

# --- Arduino IDE / CLI ---
.theia/
.vscode/
!.vscode/extensions.json
.arduino15/
sketch.json

# --- PlatformIO (if anyone builds it that way) ---
.pio/
.pioenvs/
.piolibdeps/

# --- OS cruft ---
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.DS_Store
._*

# --- Editors ---
*.swp
*~
.idea/
