# Normalize line endings: store LF in the repo, check out native on each OS.
# Keeps Windows/Linux/Mac contributors from generating whole-file diffs.
* text=auto

# Source
*.ino    text diff=cpp
*.h      text diff=cpp
*.cpp    text diff=cpp
*.md     text
*.txt    text

# Binary — never touch these
*.jpg    binary
*.jpeg   binary
*.png    binary
*.gif    binary
*.mp4    binary
*.bin    binary
*.stl    binary
*.step   binary
